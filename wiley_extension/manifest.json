{
  "manifest_version": 3,
  "name": "WileyPLUS AI Bridge",
  "version": "3.0",
  "description": "Sends WileyPLUS content to local AI agent via Playwright",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://*.wiley.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
