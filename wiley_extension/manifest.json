{
  "manifest_version": 3,
  "name": "WileyPLUS AI Bridge",
  "version": "2.0",
  "description": "Sends WileyPLUS content to local AI agent via Playwright",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.wiley.com/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://*.wiley.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
